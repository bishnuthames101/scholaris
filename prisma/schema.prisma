// Scholaris — multi-tenant School Management System
// Conventions (per docs/SMS_MASTER_PLAN.md §5.4):
//  - BigInt autoincrement PKs internal only; public_id (UUID) for all external references
//  - tenant_id on every tenant-owned row, enforced by Postgres RLS
//  - Soft deletes via deleted_at; audit_log is append-only

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// Tenancy
// ─────────────────────────────────────────────────────────────

enum TenantStatus {
  active
  suspended
  trial
  churned
}

model Tenant {
  id              BigInt       @id @default(autoincrement())
  publicId        String       @unique @default(uuid()) @map("public_id") @db.Uuid
  name            String
  nameNe          String?      @map("name_ne")
  slug            String       @unique
  address         String?
  phone           String?
  email           String?
  panVatNo        String?      @map("pan_vat_no")
  logoUrl         String?      @map("logo_url")
  fiscalYearStart Int          @default(4) @map("fiscal_year_start") // BS month index (Shrawan = 4)
  defaultLocale   String       @default("en") @map("default_locale")
  status          TenantStatus @default(trial)
  settings        Json         @default("{}")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  users         User[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────
// Users, roles, permissions (RBAC permission matrix — §5.5)
// ─────────────────────────────────────────────────────────────

enum UserStatus {
  active
  inactive
  invited
}

model User {
  id           BigInt     @id @default(autoincrement())
  publicId     String     @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId     BigInt?    @map("tenant_id") // null = superadmin (platform-level)
  name         String
  nameNe       String?    @map("name_ne")
  email        String?
  phone        String?
  passwordHash String     @map("password_hash")
  locale       String     @default("en")
  status       UserStatus @default(active)
  isSuperadmin Boolean    @default(false) @map("is_superadmin")
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  tenant         Tenant?         @relation(fields: [tenantId], references: [id])
  userRoles      UserRole[]
  refreshTokens  RefreshToken[]
  passwordResets PasswordReset[]

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId])
  @@map("users")
}

model Role {
  id        BigInt    @id @default(autoincrement())
  publicId  String    @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId  BigInt?   @map("tenant_id") // null = system role available to all tenants
  key       String // superadmin, school_admin, principal, accountant, teacher, class_teacher, parent, student, librarian, transport, front_desk
  name      String
  nameNe    String?   @map("name_ne")
  isSystem  Boolean   @default(false) @map("is_system")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id       BigInt @id @default(autoincrement())
  key      String @unique // e.g. "students.read", "fees.invoice.create"
  resource String // e.g. "students"
  action   String // e.g. "read"

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       BigInt @map("role_id")
  permissionId BigInt @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId BigInt @map("user_id")
  roleId BigInt @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ─────────────────────────────────────────────────────────────
// Auth support
// ─────────────────────────────────────────────────────────────

model RefreshToken {
  id        BigInt    @id @default(autoincrement())
  publicId  String    @unique @default(uuid()) @map("public_id") @db.Uuid
  userId    BigInt    @map("user_id")
  tenantId  BigInt?   @map("tenant_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent")
  ip        String?
  createdAt DateTime  @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

// ─────────────────────────────────────────────────────────────
// Audit log (append-only, immutable — §3.3 / §5.8)
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  publicId  String   @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId  BigInt?  @map("tenant_id")
  actorId   BigInt?  @map("actor_id") // user id; null for system jobs
  action    String // create | update | soft_delete | login | ...
  entity    String // table/entity name
  entityId  String?  @map("entity_id") // public_id of the affected row
  before    Json?
  after     Json?
  reason    String?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_log")
}

// ─────────────────────────────────────────────────────────────
// Phase 1 — Core SIS (§6, Phase 1)
// ─────────────────────────────────────────────────────────────

model AcademicYear {
  id        BigInt    @id @default(autoincrement())
  publicId  String    @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId  BigInt    @map("tenant_id")
  name      String // e.g. "2082"
  startsAt  DateTime  @map("starts_at")
  endsAt    DateTime  @map("ends_at")
  isCurrent Boolean   @default(false) @map("is_current")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  enrollments Enrollment[]
  exams       Exam[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("academic_years")
}

enum Stream {
  science
  management
  humanities
  education
}

model SchoolClass {
  id         BigInt    @id @default(autoincrement())
  publicId   String    @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId   BigInt    @map("tenant_id")
  gradeLevel Int       @map("grade_level") // -1 = ECD, 0 = KG, 1..12
  stream     Stream? // grades 11-12 only
  name       String // "Class 5", "11 Science"
  nameNe     String?   @map("name_ne")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  sections     Section[]
  subjects     Subject[]
  examSubjects ExamSubject[]

  @@unique([tenantId, gradeLevel, stream])
  @@index([tenantId])
  @@map("classes")
}

model Section {
  id             BigInt    @id @default(autoincrement())
  publicId       String    @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId       BigInt    @map("tenant_id")
  classId        BigInt    @map("class_id")
  name           String // "A", "B"
  classTeacherId BigInt?   @map("class_teacher_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  class        SchoolClass        @relation(fields: [classId], references: [id])
  classTeacher Staff?             @relation(fields: [classTeacherId], references: [id])
  enrollments  Enrollment[]
  attendance   AttendanceRecord[]

  @@unique([tenantId, classId, name])
  @@index([tenantId])
  @@map("sections")
}

model Subject {
  id           BigInt    @id @default(autoincrement())
  publicId     String    @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId     BigInt    @map("tenant_id")
  classId      BigInt    @map("class_id")
  name         String
  nameNe       String?   @map("name_ne")
  code         String?
  hasPractical Boolean   @default(false) @map("has_practical")
  fullMarksTh  Int       @default(100) @map("full_marks_th")
  passMarksTh  Int       @default(35) @map("pass_marks_th")
  fullMarksPr  Int?      @map("full_marks_pr")
  passMarksPr  Int?      @map("pass_marks_pr")
  creditHours  Decimal?  @map("credit_hours") @db.Decimal(4, 2)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  class        SchoolClass   @relation(fields: [classId], references: [id])
  examSubjects ExamSubject[]

  @@unique([tenantId, classId, name])
  @@index([tenantId])
  @@map("subjects")
}

enum Gender {
  male
  female
  other
}

enum StudentStatus {
  active
  transferred
  graduated
  dropped
}

model Student {
  id          BigInt        @id @default(autoincrement())
  publicId    String        @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId    BigInt        @map("tenant_id")
  admissionNo String        @map("admission_no")
  name        String
  nameNe      String?       @map("name_ne")
  gender      Gender
  dob         DateTime?
  photoUrl    String?       @map("photo_url")
  address     String?
  phone       String?
  bloodGroup  String?       @map("blood_group")
  rfidUid     String?       @map("rfid_uid")
  status      StudentStatus @default(active)
  admittedAt  DateTime?     @map("admitted_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  guardians     StudentGuardian[]
  enrollments   Enrollment[]
  attendance    AttendanceRecord[]
  discounts     StudentDiscount[]
  invoices      Invoice[]
  payments      Payment[]
  ledgerEntries LedgerEntry[]
  marks         Mark[]
  examResults   ExamResult[]

  @@unique([tenantId, admissionNo])
  @@unique([tenantId, rfidUid])
  @@index([tenantId, name])
  @@index([tenantId, status])
  @@map("students")
}

enum Channel {
  whatsapp
  sms
  viber
  push
}

model Guardian {
  id               BigInt    @id @default(autoincrement())
  publicId         String    @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId         BigInt    @map("tenant_id")
  name             String
  nameNe           String?   @map("name_ne")
  phone            String
  phone2           String?
  email            String?
  occupation       String?
  address          String?
  preferredChannel Channel   @default(whatsapp) @map("preferred_channel")
  userId           BigInt?   @map("user_id") // portal login (Phase 6)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  students StudentGuardian[]

  @@index([tenantId, phone])
  @@index([tenantId])
  @@map("guardians")
}

enum GuardianRelation {
  father
  mother
  grandfather
  grandmother
  uncle
  aunt
  brother
  sister
  other
}

model StudentGuardian {
  studentId  BigInt           @map("student_id")
  guardianId BigInt           @map("guardian_id")
  relation   GuardianRelation @default(other)
  isPrimary  Boolean          @default(false) @map("is_primary")

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@id([studentId, guardianId])
  @@map("student_guardians")
}

enum StaffStatus {
  active
  on_leave
  resigned
}

model Staff {
  id          BigInt      @id @default(autoincrement())
  publicId    String      @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId    BigInt      @map("tenant_id")
  userId      BigInt?     @map("user_id")
  name        String
  nameNe      String?     @map("name_ne")
  designation String // "Teacher", "Accountant", ...
  phone       String?
  email       String?
  photoUrl    String?     @map("photo_url")
  joinedAt    DateTime?   @map("joined_at")
  status      StaffStatus @default(active)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  sections Section[]

  @@index([tenantId])
  @@map("staff")
}

enum EnrollmentStatus {
  enrolled
  promoted
  transferred
  graduated
  dropped
}

model Enrollment {
  id             BigInt           @id @default(autoincrement())
  publicId       String           @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId       BigInt           @map("tenant_id")
  studentId      BigInt           @map("student_id")
  academicYearId BigInt           @map("academic_year_id")
  sectionId      BigInt           @map("section_id")
  rollNo         Int?             @map("roll_no")
  status         EnrollmentStatus @default(enrolled)
  enrolledAt     DateTime         @default(now()) @map("enrolled_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  student      Student      @relation(fields: [studentId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  section      Section      @relation(fields: [sectionId], references: [id])

  @@unique([studentId, academicYearId])
  @@index([tenantId, sectionId, academicYearId])
  @@map("enrollments")
}

// ─────────────────────────────────────────────────────────────
// Phase 2 — Attendance + RFID ingestion (§6 Phase 2, §7)
// ─────────────────────────────────────────────────────────────

enum AttendanceStatus {
  present
  absent
  late
  leave
}

enum AttendanceSource {
  manual
  rfid
  system // created by the daily absence job
}

model AttendanceRecord {
  id               BigInt           @id @default(autoincrement())
  publicId         String           @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId         BigInt           @map("tenant_id")
  studentId        BigInt           @map("student_id")
  sectionId        BigInt?          @map("section_id") // roster context when marked
  date             DateTime         @db.Date
  status           AttendanceStatus
  source           AttendanceSource
  firstTapAt       DateTime?        @map("first_tap_at")
  lastTapAt        DateTime?        @map("last_tap_at")
  markedBy         String?          @map("marked_by") // user publicId; null for rfid/system
  note             String?
  absentNotifiedAt DateTime?        @map("absent_notified_at") // set when attendance.absent emitted (exactly-once)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  student Student  @relation(fields: [studentId], references: [id])
  section Section? @relation(fields: [sectionId], references: [id])

  @@unique([tenantId, studentId, date])
  @@index([tenantId, date])
  @@index([tenantId, sectionId, date])
  @@map("attendance_records")
}

enum RfidDeviceLocation {
  gate
  classroom
  bus
}

model RfidDevice {
  id             BigInt             @id @default(autoincrement())
  publicId       String             @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId       BigInt             @map("tenant_id")
  deviceId       String             @map("device_id") // hardware identifier, e.g. "GATE-01"
  name           String
  location       RfidDeviceLocation @default(gate)
  secret         String // HMAC-SHA256 key (server must keep raw to verify signatures)
  isActive       Boolean            @default(true) @map("is_active")
  lastSeenAt     DateTime?          @map("last_seen_at") // any authenticated contact
  lastReportedAt DateTime?          @map("last_reported_at") // last batch containing >=1 swipe (drives reported_today guard)
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  deletedAt      DateTime?          @map("deleted_at")

  events RfidEvent[]

  @@unique([tenantId, deviceId])
  @@index([tenantId])
  @@map("rfid_devices")
}

enum RfidDirection {
  in
  out
}

// Raw taps — append-only; dedupe key (device, uid, tapped_at) makes ingestion idempotent/replay-safe.
model RfidEvent {
  id          BigInt         @id @default(autoincrement())
  tenantId    BigInt         @map("tenant_id")
  deviceId    BigInt         @map("device_id")
  rfidUid     String         @map("rfid_uid")
  tappedAt    DateTime       @map("tapped_at")
  direction   RfidDirection?
  syncBatchId String?        @map("sync_batch_id")
  studentId   BigInt?        @map("student_id") // resolved uid→student (null = unknown card)
  processedAt DateTime?      @map("processed_at")
  createdAt   DateTime       @default(now()) @map("created_at")

  device RfidDevice @relation(fields: [deviceId], references: [id])

  @@unique([deviceId, rfidUid, tappedAt])
  @@index([tenantId, tappedAt])
  @@map("rfid_events")
}

// Outbox for domain events ("rfid.tap", "attendance.absent") — Phase 5 notification router consumes.
model DomainEvent {
  id          BigInt    @id @default(autoincrement())
  publicId    String    @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId    BigInt    @map("tenant_id")
  type        String // "rfid.tap" | "attendance.absent" | ...
  payload     Json
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([tenantId, type, createdAt])
  @@index([processedAt])
  @@map("domain_events")
}

enum AbsenceRunStatus {
  completed
  held // offline-vs-absent guard: no data reported — do NOT message, flag for review
  skipped // messaging mode off
}

model AbsenceRun {
  id            BigInt           @id @default(autoincrement())
  publicId      String           @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId      BigInt           @map("tenant_id")
  date          DateTime         @db.Date
  status        AbsenceRunStatus
  heldReason    String?          @map("held_reason")
  absentCount   Int              @default(0) @map("absent_count")
  presentCount  Int              @default(0) @map("present_count")
  eventsEmitted Int              @default(0) @map("events_emitted")
  summary       Json             @default("{}")
  ranBy         String?          @map("ran_by") // user publicId; null = scheduled job
  createdAt     DateTime         @default(now()) @map("created_at")

  @@index([tenantId, date, createdAt])
  @@map("absence_runs")
}

// ============================================================
// Phase 3 — Fees & finance (IRD/CBMS-ready)
// All monetary values are integer paisa (1 NPR = 100 paisa).
// ============================================================

enum FeeFrequency {
  monthly
  quarterly
  annual
  one_time
}

model FeeHead {
  id        BigInt    @id @default(autoincrement())
  publicId  String    @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId  BigInt    @map("tenant_id")
  name      String
  nameNe    String?   @map("name_ne")
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  structures FeeStructure[]
  discounts  StudentDiscount[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("fee_heads")
}

// class × head × amount × frequency, per academic year
model FeeStructure {
  id             BigInt       @id @default(autoincrement())
  publicId       String       @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId       BigInt       @map("tenant_id")
  academicYearId BigInt       @map("academic_year_id")
  classId        BigInt       @map("class_id")
  feeHeadId      BigInt       @map("fee_head_id")
  amountPaisa    Int          @map("amount_paisa")
  frequency      FeeFrequency @default(monthly)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  feeHead FeeHead @relation(fields: [feeHeadId], references: [id])

  @@unique([tenantId, academicYearId, classId, feeHeadId])
  @@index([tenantId, academicYearId, classId])
  @@map("fee_structures")
}

enum DiscountType {
  percent // value = 0..100
  fixed // value = paisa per billing cycle
}

// Scholarships / sibling discounts etc.; feeHeadId null = applies to every head.
model StudentDiscount {
  id        BigInt       @id @default(autoincrement())
  publicId  String       @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId  BigInt       @map("tenant_id")
  studentId BigInt       @map("student_id")
  feeHeadId BigInt?      @map("fee_head_id")
  type      DiscountType
  value     Int // percent or paisa depending on type
  reason    String?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  student Student  @relation(fields: [studentId], references: [id])
  feeHead FeeHead? @relation(fields: [feeHeadId], references: [id])

  @@index([tenantId, studentId])
  @@map("student_discounts")
}

// Atomic per-fiscal-year document numbering (invoices, receipts).
model DocCounter {
  id         BigInt @id @default(autoincrement())
  tenantId   BigInt @map("tenant_id")
  kind       String // "invoice" | "receipt"
  fiscalYear String @map("fiscal_year") // "2082/83"
  value      Int    @default(0)

  @@unique([tenantId, kind, fiscalYear])
  @@map("doc_counters")
}

enum InvoiceStatus {
  issued
  partially_paid
  paid
  void // reversal via ledger entry; never hard-deleted
}

model Invoice {
  id             BigInt        @id @default(autoincrement())
  publicId       String        @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId       BigInt        @map("tenant_id")
  invoiceNo      String        @map("invoice_no") // "2082/83-INV-000123"
  fiscalYear     String        @map("fiscal_year")
  seq            Int
  studentId      BigInt        @map("student_id")
  academicYearId BigInt        @map("academic_year_id")
  bsYear         Int           @map("bs_year")
  bsMonth        Int?          @map("bs_month") // 1=Baishakh; null for one-time/annual billing
  issueDate      DateTime      @map("issue_date") @db.Date
  dueDate        DateTime?     @map("due_date") @db.Date
  subtotalPaisa  Int           @map("subtotal_paisa")
  discountPaisa  Int           @default(0) @map("discount_paisa")
  finePaisa      Int           @default(0) @map("fine_paisa")
  totalPaisa     Int           @map("total_paisa")
  paidPaisa      Int           @default(0) @map("paid_paisa")
  status         InvoiceStatus @default(issued)
  voidReason     String?       @map("void_reason")
  voidedAt       DateTime?     @map("voided_at")
  printCount     Int           @default(0) @map("print_count") // >0 → "Copy of Original"
  note           String?
  createdBy      String?       @map("created_by") // user publicId
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  student  Student       @relation(fields: [studentId], references: [id])
  items    InvoiceItem[]
  payments Payment[]

  @@unique([tenantId, invoiceNo])
  @@unique([tenantId, fiscalYear, seq])
  @@index([tenantId, studentId, createdAt])
  @@index([tenantId, status, dueDate])
  @@index([tenantId, bsYear, bsMonth])
  @@map("invoices")
}

enum InvoiceItemKind {
  fee
  fine
}

model InvoiceItem {
  id            BigInt          @id @default(autoincrement())
  tenantId      BigInt          @map("tenant_id")
  invoiceId     BigInt          @map("invoice_id")
  feeHeadId     BigInt?         @map("fee_head_id")
  kind          InvoiceItemKind @default(fee)
  label         String // snapshot of head name at issue time
  labelNe       String?         @map("label_ne")
  amountPaisa   Int             @map("amount_paisa")
  discountPaisa Int             @default(0) @map("discount_paisa")

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([tenantId, invoiceId])
  @@map("invoice_items")
}

enum PaymentMethod {
  cash
  bank
  esewa
  khalti
}

enum PaymentStatus {
  pending // online payment initiated, awaiting verification
  completed
  failed
  cancelled
}

model Payment {
  id              BigInt        @id @default(autoincrement())
  publicId        String        @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId        BigInt        @map("tenant_id")
  receiptNo       String?       @map("receipt_no") // assigned on completion: "2082/83-RCP-000045"
  fiscalYear      String        @map("fiscal_year")
  seq             Int?
  invoiceId       BigInt        @map("invoice_id")
  studentId       BigInt        @map("student_id")
  method          PaymentMethod
  amountPaisa     Int           @map("amount_paisa")
  status          PaymentStatus @default(pending)
  reference       String? // cheque no / bank voucher ref
  providerRef     String?       @map("provider_ref") // eSewa/Khalti txn id
  providerPayload Json?         @map("provider_payload")
  paidAt          DateTime?     @map("paid_at")
  receivedBy      String?       @map("received_by") // user publicId for manual entry
  printCount      Int           @default(0) @map("print_count")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([tenantId, receiptNo])
  @@unique([tenantId, fiscalYear, seq])
  @@index([tenantId, invoiceId])
  @@index([tenantId, status, paidAt])
  @@map("payments")
}

enum LedgerEntryType {
  invoice_issued
  payment_received
  payment_reversed
  invoice_voided
}

// Append-only financial ledger (IRD/CBMS boundary). RLS forbids UPDATE and DELETE.
model LedgerEntry {
  id          BigInt          @id @default(autoincrement())
  publicId    String          @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId    BigInt          @map("tenant_id")
  studentId   BigInt          @map("student_id")
  invoiceId   BigInt?         @map("invoice_id")
  paymentId   BigInt?         @map("payment_id")
  type        LedgerEntryType
  debitPaisa  Int             @default(0) @map("debit_paisa") // charges to student
  creditPaisa Int             @default(0) @map("credit_paisa") // payments / reversals of charges
  narration   String
  meta        Json            @default("{}")
  createdBy   String?         @map("created_by")
  createdAt   DateTime        @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id])

  @@index([tenantId, studentId, createdAt])
  @@index([tenantId, createdAt])
  @@map("ledger_entries")
}

// ============================================================
// Phase 4 — Examinations & grading (NEB, §3.2)
// Marks are numeric (Decimal); grades/GPA computed from the
// tenant-configurable grade scale and snapshotted on publish.
// ============================================================

// Per-tenant configurable grading scale; NEB 4.0 seeded as default.
model GradeScale {
  id        BigInt    @id @default(autoincrement())
  publicId  String    @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId  BigInt    @map("tenant_id")
  name      String // e.g. "NEB 4.0 (2078 BS)"
  isDefault Boolean   @default(false) @map("is_default")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  bands GradeBand[]
  exams Exam[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("grade_scales")
}

// A band: percent range → letter + grade point. NG (0.0) is the fail band.
model GradeBand {
  id           BigInt  @id @default(autoincrement())
  tenantId     BigInt  @map("tenant_id")
  gradeScaleId BigInt  @map("grade_scale_id")
  letter       String // "A+", "A", … "NG"
  letterNe     String? @map("letter_ne")
  gradePoint   Decimal @map("grade_point") @db.Decimal(3, 2) // 4.00 … 0.00
  minPercent   Decimal @map("min_percent") @db.Decimal(5, 2) // inclusive
  maxPercent   Decimal @map("max_percent") @db.Decimal(5, 2) // inclusive at 100
  isPassing    Boolean @default(true) @map("is_passing")
  sortOrder    Int     @default(0) @map("sort_order")

  gradeScale GradeScale @relation(fields: [gradeScaleId], references: [id])

  @@unique([gradeScaleId, letter])
  @@index([tenantId])
  @@map("grade_bands")
}

enum ExamType {
  unit
  terminal
  board
}

enum ExamStatus {
  draft // marks entry open
  published // results visible; marks locked (audited unlock available)
}

model Exam {
  id             BigInt     @id @default(autoincrement())
  publicId       String     @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId       BigInt     @map("tenant_id")
  academicYearId BigInt     @map("academic_year_id")
  gradeScaleId   BigInt     @map("grade_scale_id")
  name           String // "First Terminal Examination 2082"
  nameNe         String?    @map("name_ne")
  type           ExamType   @default(terminal)
  status         ExamStatus @default(draft)
  startsAt       DateTime?  @map("starts_at") @db.Date
  endsAt         DateTime?  @map("ends_at") @db.Date
  publishedAt    DateTime?  @map("published_at")
  publishedBy    String?    @map("published_by") // user publicId
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  academicYear AcademicYear  @relation(fields: [academicYearId], references: [id])
  gradeScale   GradeScale    @relation(fields: [gradeScaleId], references: [id])
  subjects     ExamSubject[]
  marks        Mark[]
  results      ExamResult[]

  @@unique([tenantId, academicYearId, name])
  @@index([tenantId, academicYearId])
  @@map("exams")
}

// Which subject is examined for which class, with marks config snapshotted
// from Subject at setup time (subjects can change later; the exam must not).
model ExamSubject {
  id           BigInt    @id @default(autoincrement())
  publicId     String    @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId     BigInt    @map("tenant_id")
  examId       BigInt    @map("exam_id")
  classId      BigInt    @map("class_id")
  subjectId    BigInt    @map("subject_id")
  hasPractical Boolean   @default(false) @map("has_practical")
  fullMarksTh  Int       @map("full_marks_th")
  passMarksTh  Int       @map("pass_marks_th")
  fullMarksPr  Int?      @map("full_marks_pr")
  passMarksPr  Int?      @map("pass_marks_pr")
  examDate     DateTime? @map("exam_date") @db.Date
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  exam    Exam        @relation(fields: [examId], references: [id])
  class   SchoolClass @relation(fields: [classId], references: [id])
  subject Subject     @relation(fields: [subjectId], references: [id])
  marks   Mark[]

  @@unique([examId, subjectId])
  @@index([tenantId, examId, classId])
  @@map("exam_subjects")
}

// One row per student × exam-subject. Numeric marks entered by teachers;
// grade fields are computed (preview live, snapshotted on publish).
model Mark {
  id            BigInt    @id @default(autoincrement())
  publicId      String    @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId      BigInt    @map("tenant_id")
  examId        BigInt    @map("exam_id")
  examSubjectId BigInt    @map("exam_subject_id")
  studentId     BigInt    @map("student_id")
  marksTh       Decimal?  @map("marks_th") @db.Decimal(6, 2)
  marksPr       Decimal?  @map("marks_pr") @db.Decimal(6, 2)
  isAbsent      Boolean   @default(false) @map("is_absent")
  // Computed on publish (snapshot — survives later grade-scale edits):
  percent       Decimal?  @db.Decimal(5, 2)
  gradeLetter   String?   @map("grade_letter")
  gradePoint    Decimal?  @map("grade_point") @db.Decimal(3, 2)
  enteredBy     String?   @map("entered_by") // user publicId
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  exam        Exam        @relation(fields: [examId], references: [id])
  examSubject ExamSubject @relation(fields: [examSubjectId], references: [id])
  student     Student     @relation(fields: [studentId], references: [id])

  @@unique([examSubjectId, studentId])
  @@index([tenantId, examId, studentId])
  @@map("marks")
}

enum ExamResultStatus {
  passed
  failed // one or more NG subjects — clearable via grade-increment exam
}

// Per student × exam summary, computed at publish time (marksheet source).
model ExamResult {
  id          BigInt           @id @default(autoincrement())
  publicId    String           @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId    BigInt           @map("tenant_id")
  examId      BigInt           @map("exam_id")
  studentId   BigInt           @map("student_id")
  gpa         Decimal          @db.Decimal(3, 2) // average of subject grade points
  status      ExamResultStatus
  ngCount     Int              @default(0) @map("ng_count")
  summary     Json             @default("{}") // per-subject snapshot for the marksheet
  computedAt  DateTime         @default(now()) @map("computed_at")
  printCount  Int              @default(0) @map("print_count")

  exam    Exam    @relation(fields: [examId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([examId, studentId])
  @@index([tenantId, examId])
  @@map("exam_results")
}

// ============================================================
// Phase 5 — Communication hub (Notifier convergence, §5.6)
// Multi-channel notification engine with templates, routing,
// credit metering, and domain-event triggers.
// ============================================================

enum NotificationChannel {
  whatsapp
  sms
  viber
  push
}

enum NotificationStatus {
  pending
  queued
  sent
  delivered
  failed
  cancelled
}

// Bilingual message templates with variable placeholders.
// e.g. "Dear {{guardianName}}, your child {{studentName}} was absent on {{date}}"
model NotificationTemplate {
  id        BigInt    @id @default(autoincrement())
  publicId  String    @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId  BigInt    @map("tenant_id")
  name      String // "Absence Alert"
  nameNe    String?   @map("name_ne")
  slug      String // "absence_alert" — machine-friendly key for event binding
  bodyEn    String    @map("body_en") @db.Text
  bodyNe    String?   @map("body_ne") @db.Text
  variables String[]  @default([]) // ["guardianName","studentName","date","class"]
  isSystem  Boolean   @default(false) @map("is_system") // seeded defaults, not deletable
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  notifications Notification[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("notification_templates")
}

// A single notification intent (may fan out to multiple message attempts across channels).
model Notification {
  id             BigInt             @id @default(autoincrement())
  publicId       String             @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId       BigInt             @map("tenant_id")
  templateId     BigInt?            @map("template_id")
  recipientPhone String?            @map("recipient_phone") // denormalized for routing
  recipientName  String?            @map("recipient_name")
  guardianId     BigInt?            @map("guardian_id")
  studentId      BigInt?            @map("student_id")
  channel        NotificationChannel // actual channel used
  status         NotificationStatus @default(pending)
  subject        String? // optional subject line
  bodyEn         String             @map("body_en") @db.Text // rendered body (EN)
  bodyNe         String?            @map("body_ne") @db.Text // rendered body (NE)
  variables      Json               @default("{}") // template variable values
  triggerType    String?            @map("trigger_type") // "attendance.absent", "fee.due", "bulk", ...
  triggerEventId BigInt?            @map("trigger_event_id") // link to domain_events.id
  sentAt         DateTime?          @map("sent_at")
  deliveredAt    DateTime?          @map("delivered_at")
  failedAt       DateTime?          @map("failed_at")
  errorMessage   String?            @map("error_message")
  retryCount     Int                @default(0) @map("retry_count")
  costPaisa      Int                @default(0) @map("cost_paisa") // metered cost
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  template NotificationTemplate? @relation(fields: [templateId], references: [id])

  @@index([tenantId, status, createdAt])
  @@index([tenantId, triggerType, createdAt])
  @@index([tenantId, guardianId])
  @@index([tenantId, studentId])
  @@map("notifications")
}

// Per-tenant message credit balance + usage tracking.
model MessageCredit {
  id        BigInt   @id @default(autoincrement())
  publicId  String   @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId  BigInt   @unique @map("tenant_id") // one row per tenant
  balance   Int      @default(0) // remaining credits
  totalUsed Int      @default(0) @map("total_used")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("message_credits")
}

// Credit ledger — every credit add/deduct is tracked.
model CreditTransaction {
  id          BigInt   @id @default(autoincrement())
  publicId    String   @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId    BigInt   @map("tenant_id")
  amount      Int // positive = added, negative = consumed
  balanceAfter Int     @map("balance_after")
  reason      String // "topup", "absence_alert", "bulk_send", "admin_adjustment"
  reference   String? // notification publicId, invoice ref, etc.
  createdBy   String?  @map("created_by") // user publicId
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("credit_transactions")
}

// Contact groups for bulk sending (class parents, staff, custom segments).
model ContactGroup {
  id        BigInt    @id @default(autoincrement())
  publicId  String    @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId  BigInt    @map("tenant_id")
  name      String
  nameNe    String?   @map("name_ne")
  type      String    @default("custom") // "custom", "class_parents", "staff", "all_parents"
  filter    Json      @default("{}") // for dynamic groups: { classId, sectionId, ... }
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  members ContactGroupMember[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("contact_groups")
}

model ContactGroupMember {
  id         BigInt  @id @default(autoincrement())
  tenantId   BigInt  @map("tenant_id")
  groupId    BigInt  @map("group_id")
  guardianId BigInt? @map("guardian_id")
  phone      String? // for non-guardian contacts
  name       String?

  group ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, guardianId])
  @@unique([groupId, phone])
  @@index([tenantId])
  @@map("contact_group_members")
}
