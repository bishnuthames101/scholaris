  updatedAt   DateTime      @updatedAt @map("updated_at")

  slips PayrollSlip[]

  @@unique([tenantId, bsYear, bsMonth])
  @@index([tenantId, fiscalYear])
  @@map("payrolls")
}

model PayrollSlip {
  id              BigInt   @id @default(autoincrement())
  publicId        String   @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId        BigInt   @map("tenant_id")
  payrollId       BigInt   @map("payroll_id")
  staffId         BigInt   @map("staff_id")
  basicPaisa      Int      @map("basic_paisa")
  allowancesPaisa Int      @map("allowances_paisa")
  deductionsPaisa Int      @map("deductions_paisa")
  netPaisa        Int      @map("net_paisa")
  presentDays     Int      @map("present_days")
  absentDays      Int      @map("absent_days")
  leaveDays       Int      @map("leave_days")
  breakdown       Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  payroll Payroll @relation(fields: [payrollId], references: [id])
  staff   Staff   @relation(fields: [staffId], references: [id])

  @@unique([payrollId, staffId])
  @@index([tenantId, staffId])
  @@map("payroll_slips")
}

// ============================================================
// Phase 8D — Admissions & Enquiry CRM
// ============================================================

enum EnquirySource {
  walk_in
  phone
  website
  referral
  social_media
  other
}

enum EnquiryStatus {
  new_enquiry @map("new")
  contacted
  visit_scheduled
  visited
  application_sent
  converted
  lost
}

model Enquiry {
  id                 BigInt        @id @default(autoincrement())
  publicId           String        @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId           BigInt        @map("tenant_id")
  academicYearId     BigInt        @map("academic_year_id")
  studentName        String        @map("student_name")
  studentNameNe      String?       @map("student_name_ne")
  gender             Gender?
  dob                DateTime?
  applyingForClassId BigInt?       @map("applying_for_class_id")
  guardianName       String        @map("guardian_name")
  guardianPhone      String        @map("guardian_phone")
  guardianEmail      String?       @map("guardian_email")
  address            String?
  source             EnquirySource @default(walk_in)
  status             EnquiryStatus @default(new_enquiry)
  assignedTo         String?       @map("assigned_to")
  note               String?       @db.Text
  lastContactedAt    DateTime?     @map("last_contacted_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  deletedAt          DateTime?     @map("deleted_at")

  academicYear     AcademicYear  @relation(fields: [academicYearId], references: [id])
  applyingForClass SchoolClass?  @relation(fields: [applyingForClassId], references: [id])
  followUps        EnquiryFollowUp[]
  application      AdmissionApplication?

  @@index([tenantId, status])
  @@index([tenantId, academicYearId])
  @@index([tenantId, guardianPhone])
  @@map("enquiries")
}

model EnquiryFollowUp {
  id           BigInt    @id @default(autoincrement())
  publicId     String    @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId     BigInt    @map("tenant_id")
  enquiryId    BigInt    @map("enquiry_id")
  note         String    @db.Text
  contactedVia String?   @map("contacted_via")
  nextFollowUp DateTime? @map("next_follow_up") @db.Date
  createdBy    String?   @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")

  enquiry Enquiry @relation(fields: [enquiryId], references: [id])

  @@index([tenantId, enquiryId])
  @@map("enquiry_follow_ups")
}

enum ApplicationStatus {
  draft
  submitted
  under_review
  app_approved @map("approved")
  app_rejected @map("rejected")
  enrolled
  withdrawn
}

model AdmissionApplication {
  id                   BigInt            @id @default(autoincrement())
  publicId             String            @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId             BigInt            @map("tenant_id")
  applicationNo        String            @map("application_no")
  fiscalYear           String            @map("fiscal_year")
  seq                  Int
  academicYearId       BigInt            @map("academic_year_id")
  enquiryId            BigInt?           @unique @map("enquiry_id")
  studentName          String            @map("student_name")
  studentNameNe        String?           @map("student_name_ne")
  gender               Gender
  dob                  DateTime?
  address              String?
  phone                String?
  previousSchool       String?           @map("previous_school")
  applyingForClassId   BigInt            @map("applying_for_class_id")
  applyingForSectionId BigInt?           @map("applying_for_section_id")
  guardianName         String            @map("guardian_name")
  guardianPhone        String            @map("guardian_phone")
  guardianEmail        String?           @map("guardian_email")
  guardianRelation     GuardianRelation? @map("guardian_relation")
  documents            Json              @default("[]")
  status               ApplicationStatus @default(draft)
  reviewedBy           String?           @map("reviewed_by")
  reviewedAt           DateTime?         @map("reviewed_at")
  reviewNote           String?           @map("review_note")
  enrolledStudentId    BigInt?           @map("enrolled_student_id")
  feePaisa             Int?              @map("fee_paisa")
  createdBy            String?           @map("created_by")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")
  deletedAt            DateTime?         @map("deleted_at")

  academicYear       AcademicYear @relation(fields: [academicYearId], references: [id])
  enquiry            Enquiry?     @relation(fields: [enquiryId], references: [id])
  applyingForClass   SchoolClass  @relation(fields: [applyingForClassId], references: [id])
  applyingForSection Section?     @relation(fields: [applyingForSectionId], references: [id])

  @@unique([tenantId, applicationNo])
  @@unique([tenantId, fiscalYear, seq])
  @@index([tenantId, academicYearId, status])
  @@map("admission_applications")
}

// ─────────────────────────────────────────────────────────────
// Phase 10 — SaaS layer: plans, subscriptions, usage (§9)
// ─────────────────────────────────────────────────────────────

enum PlanTier {
  free
  starter
  professional
  enterprise
}

enum SubscriptionStatus {
  trial
  active
  past_due
  cancelled
  expired
}

// Platform-level plans (not tenant-scoped — managed by superadmin).
model Plan {
  id            BigInt   @id @default(autoincrement())
  publicId      String   @unique @default(uuid()) @map("public_id") @db.Uuid
  name          String   @unique
  nameNe        String?  @map("name_ne")
  tier          PlanTier @default(starter)
  description   String?
  descriptionNe String?  @map("description_ne")

  // Pricing (in paisa, NPR)
  monthlyPricePaisa Int @default(0) @map("monthly_price_paisa")
  annualPricePaisa  Int @default(0) @map("annual_price_paisa") // discounted yearly

  // Limits
  maxStudents         Int  @default(100) @map("max_students")
  maxStaff            Int  @default(20) @map("max_staff")
  maxMessagesPerMonth Int  @default(500) @map("max_messages_per_month")
  includedCredits     Int  @default(0) @map("included_credits") // free credits/month

  // Module access (which modules this plan can use)
  modules     String[] @default(["sis", "attendance", "fees", "exams", "communication", "notices"])
  features    Json     @default("{}") // extra feature flags: { "rfidSupport": true, "bulkSend": true, ... }

  // Ordering & visibility
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  isDefault   Boolean  @default(false) @map("is_default") // auto-assigned to new schools
  trialDays   Int      @default(30) @map("trial_days")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  subscriptions Subscription[]

  @@map("plans")
}

// One active subscription per tenant.
model Subscription {
  id        BigInt             @id @default(autoincrement())
  publicId  String             @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId  BigInt             @unique @map("tenant_id") // one per school
  planId    BigInt             @map("plan_id")
  status    SubscriptionStatus @default(trial)
  billing   String             @default("monthly") // "monthly" | "annual"

  // Period tracking
  currentPeriodStart DateTime  @map("current_period_start")
  currentPeriodEnd   DateTime  @map("current_period_end")
  trialEndsAt        DateTime? @map("trial_ends_at")
  cancelledAt        DateTime? @map("cancelled_at")

  // Usage snapshots (updated periodically)
  currentStudents Int @default(0) @map("current_students")
  currentStaff    Int @default(0) @map("current_staff")
  messagesThisMonth Int @default(0) @map("messages_this_month")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  plan   Plan   @relation(fields: [planId], references: [id])

  invoices SubscriptionInvoice[]

  @@index([tenantId])
  @@index([planId])
  @@index([status])
  @@map("subscriptions")
}

// Subscription billing invoices (your SaaS revenue).
model SubscriptionInvoice {
  id               BigInt   @id @default(autoincrement())
  publicId         String   @unique @default(uuid()) @map("public_id") @db.Uuid
  subscriptionId   BigInt   @map("subscription_id")
  tenantId         BigInt   @map("tenant_id")
  invoiceNo        String   @map("invoice_no")
  periodStart      DateTime @map("period_start")
  periodEnd        DateTime @map("period_end")
  amountPaisa      Int      @map("amount_paisa")
  discountPaisa    Int      @default(0) @map("discount_paisa")
  taxPaisa         Int      @default(0) @map("tax_paisa")
  totalPaisa       Int      @map("total_paisa")
  status           String   @default("pending") // pending | paid | overdue | void
  paidAt           DateTime? @map("paid_at")
  paymentReference String?  @map("payment_reference")
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@unique([tenantId, invoiceNo])
  @@index([tenantId, status])
  @@index([subscriptionId])
  @@map("subscription_invoices")
}

// Country/region config for internationalization-readiness (§10).
model CountryConfig {
  id        BigInt  @id @default(autoincrement())
  publicId  String  @unique @default(uuid()) @map("public_id") @db.Uuid
  code      String  @unique // ISO 3166-1 alpha-2: "NP", "IN", ...
  name      String // "Nepal"
  currency  String  @default("NPR") // ISO 4217
  currencySymbol String @default("रू") @map("currency_symbol")
  locale    String  @default("ne") // primary locale
  timezone  String  @default("Asia/Kathmandu")

  // Calendar
  calendarSystem String @default("bikram_sambat") @map("calendar_system") // bikram_sambat | gregorian
  fiscalYearStartMonth Int @default(4) @map("fiscal_year_start_month") // Shrawan for NP

  // Grade system defaults
  defaultGradeScale String @default("neb_4.0") @map("default_grade_scale")

  // Payment providers available
  paymentProviders String[] @default(["esewa", "khalti"]) @map("payment_providers")

  // Tax rules
  taxConfig Json @default("{}") @map("tax_config") // { vatRate: 13, panRequired: true, cbmsThreshold: ... }

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("country_configs")
}
