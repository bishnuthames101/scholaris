}

enum PayrollStatus {
  draft
  approved
  paid
  cancelled
}

model Payroll {
  id          BigInt        @id @default(autoincrement())
  publicId    String        @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId    BigInt        @map("tenant_id")
  bsYear      Int           @map("bs_year")
  bsMonth     Int           @map("bs_month")
  fiscalYear  String        @map("fiscal_year")
  status      PayrollStatus @default(draft)
  totalGross  Int           @map("total_gross")
  totalDeduct Int           @map("total_deduct")
  totalNet    Int           @map("total_net")
  staffCount  Int           @map("staff_count")
  approvedBy  String?       @map("approved_by")
  approvedAt  DateTime?     @map("approved_at")
  paidAt      DateTime?     @map("paid_at")
  createdBy   String?       @map("created_by")
