// Scholaris — multi-tenant School Management System
// Conventions (per docs/SMS_MASTER_PLAN.md §5.4):
//  - BigInt autoincrement PKs internal only; public_id (UUID) for all external references
//  - tenant_id on every tenant-owned row, enforced by Postgres RLS
//  - Soft deletes via deleted_at; audit_log is append-only

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// Tenancy
// ─────────────────────────────────────────────────────────────

enum TenantStatus {
  active
  suspended
  trial
  churned
}

model Tenant {
  id              BigInt       @id @default(autoincrement())
  publicId        String       @unique @default(uuid()) @map("public_id") @db.Uuid
  name            String
  nameNe          String?      @map("name_ne")
  slug            String       @unique
  address         String?
  phone           String?
  email           String?
  panVatNo        String?      @map("pan_vat_no")
  logoUrl         String?      @map("logo_url")
  fiscalYearStart Int          @default(4) @map("fiscal_year_start") // BS month index (Shrawan = 4)
  defaultLocale   String       @default("en") @map("default_locale")
  status          TenantStatus @default(trial)
  settings        Json         @default("{}")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  users         User[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────
// Users, roles, permissions (RBAC permission matrix — §5.5)
// ─────────────────────────────────────────────────────────────

enum UserStatus {
  active
  inactive
  invited
}

model User {
  id           BigInt     @id @default(autoincrement())
  publicId     String     @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId     BigInt?    @map("tenant_id") // null = superadmin (platform-level)
  name         String
  nameNe       String?    @map("name_ne")
  email        String?
  phone        String?
  passwordHash String     @map("password_hash")
  locale       String     @default("en")
  status       UserStatus @default(active)
  isSuperadmin Boolean    @default(false) @map("is_superadmin")
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  tenant         Tenant?         @relation(fields: [tenantId], references: [id])
  userRoles      UserRole[]
  refreshTokens  RefreshToken[]
  passwordResets PasswordReset[]

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId])
  @@map("users")
}

model Role {
  id          BigInt   @id @default(autoincrement())
  publicId    String   @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId    BigInt?  @map("tenant_id") // null = system role available to all tenants
  key         String // superadmin, school_admin, principal, accountant, teacher, class_teacher, parent, student, librarian, transport, front_desk
  name        String
  nameNe      String?  @map("name_ne")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id       BigInt @id @default(autoincrement())
  key      String @unique // e.g. "students.read", "fees.invoice.create"
  resource String // e.g. "students"
  action   String // e.g. "read"

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       BigInt @map("role_id")
  permissionId BigInt @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId BigInt @map("user_id")
  roleId BigInt @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ─────────────────────────────────────────────────────────────
// Auth support
// ─────────────────────────────────────────────────────────────

model RefreshToken {
  id        BigInt    @id @default(autoincrement())
  publicId  String    @unique @default(uuid()) @map("public_id") @db.Uuid
  userId    BigInt    @map("user_id")
  tenantId  BigInt?   @map("tenant_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent")
  ip        String?
  createdAt DateTime  @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

// ─────────────────────────────────────────────────────────────
// Audit log (append-only, immutable — §3.3 / §5.8)
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  publicId  String   @unique @default(uuid()) @map("public_id") @db.Uuid
  tenantId  BigInt?  @map("tenant_id")
  actorId   BigInt?  @map("actor_id") // user id; null for system jobs
  action    String // create | update | soft_delete | login | ...
  entity    String // table/entity name
  entityId  String?  @map("entity_id") // public_id of the affected row
  before    Json?
  after     Json?
  reason    String?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_log")
}
